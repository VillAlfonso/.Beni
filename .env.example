# Copy to .env and adjust. Settings changed in the app UI are stored in the DB
# and take priority over these; env values act as initial defaults.

# Server port (cloudflared should target this)
PORT=3001

# Require this key to log in from the tunnel. Leave empty to disable auth
# (safe only while you use localhost). SET THIS before exposing the tunnel.
ACCESS_KEY=

# Main roleplay model — any OpenAI-compatible endpoint.
# Local KoboldCpp default (Cydonia 24B): http://127.0.0.1:5001/v1
# LM Studio: http://127.0.0.1:1234/v1   OpenRouter: https://openrouter.ai/api/v1
# Special value "mock" streams canned text (for testing without a model).
LLM_BASE_URL=http://127.0.0.1:5001/v1
LLM_API_KEY=
LLM_MODEL=local

# Utility model for memory extraction / summaries (defaults to the main model)
UTILITY_BASE_URL=
UTILITY_API_KEY=
UTILITY_MODEL=
